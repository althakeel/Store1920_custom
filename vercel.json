{
  "crons": [
    {
      "path": "/api/cron/product-ai-autofill",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/abandoned-checkout-whatsapp",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/waslah-auto-ship",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/reconcile-payments",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/daily-admin-orders-digest",
      "schedule": "0 6 * * 1-6"
    }
  ],
  "functions": {
