# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority

# C3Xpress Courier API
C3X_USERNAME=your_c3xpress_username
C3X_PASSWORD=your_c3xpress_password
C3X_ACCOUNT_NO=your_c3xpress_account_number
C3X_COUNTRY=AE
C3X_PRODUCT=DOM
C3X_SERVICE_TYPE=NOR
C3X_PRODUCT_FALLBACKS=XPS,EXP,ECO

# Firebase Admin SDK Configuration
# Recommended on Windows: save the downloaded JSON file locally and point to it:
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account.json
# Alternative: inline JSON string (must stay on one line in .env)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project-id","private_key_id":"key-id","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@project.iam.gserviceaccount.com","client_id":"client-id","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Firebase Client Config (for public/browser use)
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc...
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-NB8H4RK9
NEXT_PUBLIC_META_PIXEL_ID=794381109763677
NEXT_PUBLIC_TIKTOK_PIXEL_ID=D3AH1CBC77U15FSVOM1G
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-18265876413
META_CAPI_ACCESS_TOKEN=your_meta_conversions_api_access_token

# Production site URL (used in invite links, emails, redirects)
NEXT_PUBLIC_APP_URL=https://store1920.com
NEXT_PUBLIC_BASE_URL=https://store1920.com

# Firebase authorized domains checklist (add in Firebase Console, not in .env):
# - localhost
# - store1920.com
# - www.store1920.com
# - store1920.store
# - store1920-7d673.firebaseapp.com

# AWS S3 Configuration (image uploads)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=store1920-images
AWS_S3_PUBLIC_URL=https://store1920-images.s3.ap-south-1.amazonaws.com
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Background jobs (product image S3 migration without browser open)
# Generate a long random string and set the same value in production
INTERNAL_JOB_SECRET=your_random_secret_here
NEXT_PUBLIC_AWS_S3_PUBLIC_URL=https://store1920-images.s3.ap-south-1.amazonaws.com
# Optional placeholder image URL (defaults to uploads/placeholder.png on your bucket)
NEXT_PUBLIC_PLACEHOLDER_IMAGE=https://store1920-images.s3.ap-south-1.amazonaws.com/uploads/placeholder.png

# ImageKit Configuration (banner images only)
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id/

# Email Configuration
EMAIL_SERVICE_PROVIDER=smtp
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@store1920.com
SMTP_PASS=your_transactional_mailbox_password
SMTP_PROMO_USER=promo@store1920.com
SMTP_PROMO_PASS=your_promotional_mailbox_password
EMAIL_FROM="Store1920 <noreply@store1920.com>"
EMAIL_FROM_TRANSACTIONAL="Store1920 <noreply@store1920.com>"
EMAIL_FROM_MARKETING="Store1920 <promo@store1920.com>"
# Optional fallback: Resend API
RESEND_API_KEY=re_xxxxxxxxxxxx
# Optional fallbacks: EMAIL_API_KEY (same as Resend key), Mailjet
EMAIL_API_KEY=your_email_api_key

# Admin Configuration
# Comma-separated. Order notification emails are BCC'd here.
ADMIN_EMAIL=admin@Store1920.com
NEXT_PUBLIC_ADMIN_EMAIL=admin@Store1920.com
# Optional: limit daily 10:00 Dubai digest to one store (otherwise all stores)
# DAILY_DIGEST_STORE_ID=
# Cron: GET /api/cron/daily-admin-orders-digest with Authorization: Bearer CRON_SECRET
# Schedule Mon–Sat 06:00 UTC (= 10:00 Asia/Dubai). Sunday skipped. Monday covers Sat 10:00→Mon 10:00.

# Application URLs
NEXT_PUBLIC_APP_URL=https://store1920.store
NEXT_PUBLIC_BASE_URL=https://store1920.store

# Store Configuration
NEXT_PUBLIC_CURRENCY_SYMBOL=AED
NEXT_PUBLIC_COUNTRY_CODE=AE
NEXT_PUBLIC_TOPBAR_ENABLED=true
NEXT_PUBLIC_TOPBAR_COUNTDOWN_LABEL=Hurry Up !
NEXT_PUBLIC_TOPBAR_COUNTDOWN_END=2026-12-31T23:59:59+04:00
NEXT_PUBLIC_TOPBAR_ITEMS=[{"id":"shipping","title":"Free Shipping","subtitle":"Special for you"},{"id":"policy","title":"Up to 90 days*","subtitle":"Price adjustment"},{"id":"rewards","title":"Signup Rewards","subtitle":"100 Coins + Free Coupons","action":"signup"}]

# Optional: Razorpay Configuration
RAZORPAY_API_KEY=your_razorpay_key
RAZORPAY_API_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_or_live_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Configure this separately in Razorpay Dashboard for both webhook endpoints.
# Webhooks fail closed when this value is absent.
RAZORPAY_WEBHOOK_SECRET=generate_a_long_random_webhook_secret

# Optional: Stripe Configuration
STRIPE_SECRET_KEY=sk_test_or_live_key
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_or_live_key
# Stripe Dashboard endpoint URL (either works):
# https://store1920.com/api/stripe
# https://store1920.com/api/stripe/webhook
# Events: checkout.session.completed, checkout.session.async_payment_succeeded,
# checkout.session.async_payment_failed, payment_intent.succeeded,
# payment_intent.canceled, payment_intent.payment_failed
# Use Snapshot payload (not Thin) — the app reads session metadata from the webhook body.

# Google Merchant Center (Merchant API — UAE / KSA)
# https://support.google.com/merchants/answer/14173602
GOOGLE_MERCHANT_ACCOUNT_ID=your_merchant_center_id
GOOGLE_MERCHANT_DATA_SOURCE_ID=your_api_data_source_id
# Or full resource name:
# GOOGLE_MERCHANT_DATA_SOURCE=accounts/123456/dataSources/104628
GOOGLE_MERCHANT_CONTENT_LANGUAGE=en
GOOGLE_MERCHANT_FEED_LABELS=AE,SA
GOOGLE_MERCHANT_DEFAULT_PRODUCT_CATEGORY=5181
GOOGLE_MERCHANT_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Optional token to protect the XML feed URL
# GOOGLE_MERCHANT_FEED_TOKEN=generate_a_long_random_secret

# Optional: Tabby BNPL (UAE)
TABBY_API_URL=https://api.tabby.ai
TABBY_SECRET_KEY=sk_live_or_test_secret_key
TABBY_MERCHANT_CODE=Store1920
NEXT_PUBLIC_TABBY_PUBLIC_KEY=pk_live_or_test_public_key
NEXT_PUBLIC_TABBY_MERCHANT_CODE=Store1920
# Secret Tabby sends in x-tabby-signature header when calling your webhook
TABBY_WEBHOOK_SECRET=generate_a_long_random_secret
TABBY_WEBHOOK_HEADER=x-tabby-signature
# Optional override (defaults to NEXT_PUBLIC_APP_URL/api/tabby/webhook)
# TABBY_WEBHOOK_URL=https://www.store1920.com/api/tabby/webhook

# Optional: Tamara BNPL (UAE production)
TAMARA_API_URL=https://api.tamara.co
TAMARA_MERCHANT_ID=your_merchant_uuid
TAMARA_MERCHANT_BASE_URL=https://store1920.com
TAMARA_API_TOKEN=your_live_merchant_jwt
TAMARA_NOTIFICATION_TOKEN=your_notification_token
NEXT_PUBLIC_TAMARA_PUBLIC_KEY=your_public_widget_key
# Optional override (defaults to TAMARA_MERCHANT_BASE_URL/api/tamara/webhook)
# TAMARA_WEBHOOK_URL=https://store1920.com/api/tamara/webhook

# Optional: Analytics / Tracking
NEXT_PUBLIC_GA_ID=UA-...

# WhatsApp Business API (Elastic WABA — https://wabacrmapi.elastic.ae)
WABA_ENABLED=true
# Full messages endpoint (same as STORE1920_WA_API_URL in WordPress)
WABA_MESSAGES_URL=https://wabacrmapi.elastic.ae/api/meta/v19.0/855078217693024/messages
# Single bearer for all templates (same as STORE1920_WA_BEARER)
WABA_API_TOKEN=your_waba_bearer_token
# Optional fallback if WABA_MESSAGES_URL is not set
WABA_API_BASE_URL=https://wabacrmapi.elastic.ae/api/meta/v19.0
WABA_PHONE_NUMBER_ID=855078217693024
# Optional per-template tokens (Elastic may issue one token per approved template)
# Per-template bearer tokens (Elastic WABA — each template has its own token)
# WABA_TOKEN_ORDER_CONFIRMATION=   → order_confirmation_final (COD / order placed)
# WABA_TOKEN_PAID_ORDER=           → confirmation_paid_order (paid card / Stripe / Tamara / Tabby)
# WABA_TOKEN_SHIPPED=              → order_shipped
# WABA_TOKEN_REMINDER=             → order_reminder_
# WABA_TOKEN_ABANDONED_CHECKOUT=   → abandoned_checkout_reminder (abandoned cart / checkout)
# WABA_TOKEN_CART_REMINDER=        → cart_reminder_1920 (legacy browse-cart only)
WABA_TEMPLATE_CART_REMINDER=cart_reminder_1920
WABA_TEMPLATE_ABANDONED_CHECKOUT=abandoned_checkout_reminder
WABA_TEMPLATE_ORDER_CONFIRMATION=order_confirmation_final
WABA_TEMPLATE_COD_CONFIRMATION=order_confirmation_final
WABA_TEMPLATE_ORDER_DELIVERED=store1920_order_delivered
WABA_TEMPLATE_PROMOTIONAL_OFFER=promotional_offer__coupon
# WABA_CART_REMINDER_FALLBACK_IMAGE=https://www.store1920.com/logo/Store1920.png
# WABA_COD_BUTTON_PATH=/orders
# WABA_DELIVERED_BUTTON_PATH=/products
# Auto-send abandoned cart/checkout WhatsApp 1 minute after customer leaves
ABANDONED_CART_WHATSAPP_AUTO_SEND=true
# ABANDONED_CART_WHATSAPP_DELAY_MS=300000
# Legacy alias (still supported):
# ABANDONED_CHECKOUT_WHATSAPP_AUTO_SEND=true
ORDER_CONFIRM_WEBHOOK_SECRET=generate_a_long_random_secret

# Waslah shipping (UAE / EMX) — staging: https://gateway-stg.waslah.ae/api/v1
# WASLAH_API_BASE_URL=https://gateway-stg.waslah.ae/api/v1
# WASLAH_API_TOKEN=your_bearer_token
# Explicit opt-in. Only orders created while this is true are enrolled; existing orders are never swept.
# WASLAH_AUTO_SHIP_ENABLED=false
# Shared Vercel cron bearer secret used by the automatic EMX recovery job.
# CRON_SECRET=generate_a_long_random_secret
# WASLAH_WEBHOOK_SECRET=generate_a_long_random_secret_and_configure_it_in_waslah
# WASLAH_API_TIMEOUT_MS=15000
# WASLAH_TRACKING_TIMEOUT_MS=8000
# WASLAH_CREATE_ORDER_PATH=/orders
# WASLAH_SENDER_ID=your_sender_address_id_from_waslah_dashboard
# WASLAH_SERVICE_ID=65f2cc65c86ee80013093256
# WASLAH_PREFERRED_COURIER=EMX
# WASLAH_SENDER_CONTACT_NAME=Store1920
# WASLAH_SENDER_COMPANY_NAME=Store1920
# WASLAH_SENDER_PHONE=+971500000000
# WASLAH_SENDER_EMAIL=support@store1920.com
# WASLAH_SENDER_STREET=Your warehouse address
# WASLAH_SENDER_CITY=Dubai
# WASLAH_SENDER_COUNTRY=ARE
# WASLAH_DEFAULT_PICKUP_DATE=2026-04-07
# WASLAH_DEFAULT_PICKUP_TIME=14:00-21:00
# WASLAH_DEFAULT_PICKUP_VEHICLE=van
# WASLAH_DEFAULT_PKG_WIDTH=30
# WASLAH_DEFAULT_PKG_HEIGHT=10
# WASLAH_DEFAULT_PKG_LENGTH=20

# Zoho CRM (Self Client OAuth — generate refresh token once via /api/zoho/exchange)
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_REFRESH_TOKEN=
# ZOHO_REGION=com
# ZOHO_API_DOMAIN=https://www.zohoapis.com
# ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
# ZOHO_ORGANIZATION_ID=from GET /inventory/v1/organizations
# ZOHO_INVENTORY_ENABLED=true
# ZOHO_INVENTORY_REFERENCE_PREFIX=Store1920-
# ZOHO_INVENTORY_SYNC_ITEMS=true
# ZOHO_INVENTORY_LOCATION_NAME=Store1920
# ZOHO_INVENTORY_LOCATION_ID=6883101000000265001
# (Nexso, Amazon Warehouse, etc. are other locations in the same org — keep Store1920 for store1920.com)
# ZOHO_CRM_ENABLED=true
# ZOHO_CRM_DEAL_STAGE=Qualification
# ZOHO_CRM_DEAL_LAYOUT_ID=
